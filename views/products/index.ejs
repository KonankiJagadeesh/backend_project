<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Products Admin Page</h2>
    <a href="/products/add">Add Product</a>

    <% if (products.length === 0) { %>
      <p>No products found. Add some!</p>
    <% } else { %>
      <ul>
        <% products.forEach(product => { %>
          <li>
            <strong><%= product.name %></strong> – <%= product.desc %> – ₹<%= product.price %><br />
            <% if (product.imageUrl) { %>
              <img src="<%= product.imageUrl %>" alt="<%= product.name %>" width="120" />
            <% } else { %>
              <em>(no image provided)</em>
            <% } %><br />
            <a href="/products/<%= product._id %>/edit">Edit</a> |
            <a href="/products/<%= product._id %>/delete">Delete</a>
          </li>
        <% }) %>
      </ul>
    <% } %>
</body>
</html>